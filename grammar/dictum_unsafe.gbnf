# dictum_unsafe.gbnf
# AUTO-GENERATED by scripts/generate_gbnf.py — do not edit by hand.
# Derived from compiler/dictumc/grammar.py (DictumGrammar).
#
# This grammar constrains generation to Dictum's full surface syntax, INCLUDING
# top-level declarations, statement keywords, and primitive type words.
# `[TOKEN: ...]` unsafe blocks. Only use this grammar when generating
# code inside an `unsafe:` block — prefer dictum_safe.gbnf otherwise.

root          ::= top-level-item+

top-level-kw  ::= "action" | "end" | "import" | "module" | "program" | "shape"

statement-kw  ::= "C" | "Type" | "a" | "action" | "all" | "alone" | "and" | "any" | "as" | "assert" | "at" | "attempt" | "bind" | "bitwise" | "by" | "call" | "const" | "constructor" | "cosine" | "defer" | "define" | "destructor" | "difference" | "divided" | "each" | "empty" | "end" | "equal" | "exponential" | "export" | "extends" | "extern" | "failure" | "false" | "fn" | "for" | "from" | "giving" | "greater" | "holding" | "holds" | "if" | "import" | "in" | "into" | "is" | "item" | "keep" | "least" | "left" | "length" | "less" | "method" | "minus" | "modulo" | "most" | "move" | "new" | "newline" | "no" | "not" | "nothing" | "of" | "on" | "or" | "otherwise" | "override" | "plus" | "possibilities" | "power" | "print" | "private" | "produce" | "produces" | "product" | "protected" | "public" | "put" | "quotient" | "raw" | "ref" | "release" | "remainder" | "repeat" | "repeating" | "return" | "right" | "room" | "root" | "run" | "set" | "shape" | "shared" | "shift" | "sine" | "square" | "stop" | "success" | "sum" | "syscall" | "takes" | "taking" | "tanh" | "than" | "the" | "then" | "times" | "transmute" | "true" | "unique" | "unsafe" | "use" | "using" | "values" | "virtual" | "weak" | "while" | "with"

type-word     ::= "array" | "bool" | "byte" | "bytes" | "const" | "count" | "decimal" | "f32" | "fractional" | "handle" | "i32" | "i64" | "list" | "move" | "nothing" | "number" | "of" | "opaque" | "pointer" | "raw" | "ref" | "result" | "shared" | "text" | "to" | "truth" | "u16" | "u32" | "u64" | "u8" | "unique" | "value" | "weak" | "whole"

# Structural tokens are left permissive (identifiers, numbers, strings,
# operators) — the parser's recursive-descent grammar (grammar.py) remains
# the authority for full structural validation; this GBNF only constrains
# the keyword surface for LLM sampling.
#
# FIX: see dictum_safe.gbnf's matching comment — [VERIFY: CATEGORY_ID] is a
# Build-pipeline-only convention not derivable from compiler/dictumc/*, so
# the generator never emitted a rule for it here either, making the token
# structurally unreachable under grammar-constrained sampling.
top-level-item ::= top-level-kw | statement-kw | type-word | identifier | number | string | ws | verify-token | punctuation | comment

verify-token    ::= "[" ws? "VERIFY" ws? ":" ws? verify-category "_" [0-9]+ ws? "]"
verify-category ::= "ARCHITECTURE" | "TYPE" | "INVARIANT" | "OPERATION" | "MEMORY" | "SAFETY"

# FIX (found via gbnf_check.py acceptance testing against real,
# already-compiling Dictum source): the auto-generator derived this
# grammar purely from grammar.py's keyword/type-word sets and never
# accounted for bare structural punctuation at all. As a result NONE
# of ":", ".", "-", or "#" were reachable anywhere outside the
# unrelated verify-token/unsafe-token literals -- which meant the
# mandatory trailing ":" on every single `program`/`module`/`shape`/
# `action` block opener could never be produced. Concretely: ZERO
# complete Dictum programs of any kind were derivable from this
# grammar's root rule, not just "some are missed" -- verified by
# feeding this project's own passing test corpus through a real GBNF
# matcher (gbnf_check.py) rather than assuming reachability from the
# keyword lists alone. Adding these fixes that unconditionally.
# FIX (found via manual reachability audit, 2026-07-11): `&` and `*`
# (address-of / dereference, parser.py parse_unary — confirmed live via
# `keep P as raw pointer to whole number with value &X` /
# `print the text *P and newline`) and `@`/`(`/`)` (extern fn's
# `@syscall("name")` form, parser.py parse_extern) were not reachable
# anywhere in this grammar. Same root cause as the `:`/`.`/`-` fix above:
# the auto-generator only scrapes grammar.py's keyword/type-word sets, and
# these are bare single-character operators, not keywords, so the
# generator had no way to know they existed. Without this fix, a Build
# model constrained to this grammar could never emit a pointer
# address-of/dereference or an extern syscall declaration -- not
# "unlikely", structurally impossible, exactly like the VERIFY-token gap.
punctuation   ::= ":" | "." | "-" | "&" | "*" | "@" | "(" | ")"
comment       ::= "#" [^\n]*
identifier    ::= [a-zA-Z_][a-zA-Z0-9_]*
number        ::= [0-9]+ ("." [0-9]+)?
string        ::= "\"" [^"]* "\""
ws            ::= [ \t\n]+


# ---------------------------------------------------------------------------
# Unsafe-token extension (dictum_unsafe.gbnf only)
# AUTO-GENERATED from compiler/dictumc/emit_c.py's _emit_unsafe_token dispatch.
# Use only when generating statements inside an `unsafe:` block.
# ---------------------------------------------------------------------------

unsafe-token-name ::= "ATOMIC_LOAD" | "ATOMIC_STORE" | "ATOMIC_ADD" | "ATOMIC_SUB" | "ATOMIC_AND" | "ATOMIC_OR" | "ATOMIC_XOR" | "ATOMIC_FAA" | "ATOMIC_FAS" | "BARRIER_ACQUIRE" | "BARRIER_RELEASE" | "BARRIER_SEQ_CST" | "BARRIER_ACQ_REL" | "BARRIER_RELAXED" | "COMPILER_BARRIER" | "DCAS_LOOP_128" | "HP_PROTECT" | "HP_READ" | "HP_CLEAR" | "HP_RETIRE" | "HP_SCAN" | "RCU_READ_LOCK" | "RCU_READ_UNLOCK" | "RCU_SYNCHRONIZE" | "RCU_ASSIGN_POINTER" | "RCU_DEREFERENCE" | "SIMD_LOAD_F32" | "SIMD_LOADU_F32" | "SIMD_LOAD_I32" | "SIMD_LOADU_I32" | "SIMD_LOAD_F64" | "SIMD_LOADU_F64" | "SIMD_LOAD_I64" | "SIMD_LOADU_I64" | "SIMD_STORE_F32" | "SIMD_STOREU_F32" | "SIMD_STORE_I32" | "SIMD_STOREU_I32" | "SIMD_ADD_F32" | "SIMD_SUB_F32" | "SIMD_MUL_F32" | "SIMD_DIV_F32" | "SIMD_SQRT_F32" | "SIMD_FMA_F32" | "SIMD_MIN_F32" | "SIMD_MAX_F32" | "SIMD_BROADCAST_F32" | "SIMD_SHUFFLE_F32" | "SIMD_BLEND_F32" | "IS_ALIGNED" | "ALIGNED_ALLOC_16" | "ALIGNED_ALLOC_32" | "ALIGNED_ALLOC_64" | "ALIGN_UP" | "ALIGN_DOWN" | "RAW_MALLOC" | "RAW_FREE" | "RAW_CALLOC" | "RAW_REALLOC" | "RAW_MEMCPY" | "RAW_MEMSET" | "RAW_MEMCMP" | "RAW_MEMMOVE" | "FFI_LOAD" | "FFI_SYMBOL" | "FFI_CALL_VOID" | "FFI_CALL_INT" | "FFI_CALL_FLOAT" | "FFI_CALL_PTR" | "FFI_CLOSE" | "BIT_SET" | "BIT_CLEAR" | "BIT_TOGGLE" | "BIT_TEST" | "BIT_COUNT" | "BIT_REVERSE" | "BIT_SCAN_FORWARD" | "BIT_SCAN_REVERSE" | "SWAP_ENDIAN_16" | "SWAP_ENDIAN_32" | "SWAP_ENDIAN_64" | "PUN_INT_TO_FLOAT" | "PUN_FLOAT_TO_INT" | "PUN_PTR_TO_INT" | "PUN_INT_TO_PTR" | "PUN_READ_UNALIGNED_16" | "PUN_READ_UNALIGNED_32" | "PUN_READ_UNALIGNED_64"

unsafe-token ::= "[" ws? unsafe-token-name ws? (":" ws? (identifier | number) ws?)* "]"
# FIX (found via gbnf_check.py): the previous rule only allowed
# whitespace AFTER each ":" -- but every single documented example
# in SKILL_BUILD.md/LANGUAGE_REFERENCE.md writes params with a space
# on BOTH sides of every ":" (e.g. "RAW_MALLOC: 8 : counter"), which
# was therefore unreachable under grammar-constrained generation.

# Override: in unsafe mode, a top-level item may also be an unsafe-token.
top-level-item ::= top-level-kw | statement-kw | type-word | identifier | number | string | ws | verify-token | unsafe-token | punctuation | comment
