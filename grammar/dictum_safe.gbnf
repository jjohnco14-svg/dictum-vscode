# dictum_safe.gbnf
# AUTO-GENERATED by scripts/generate_gbnf.py — do not edit by hand.
# Derived from compiler/dictumc/grammar.py (DictumGrammar).
#
# This grammar constrains generation to Dictum's "safe" surface syntax:
# top-level declarations, statement keywords, and primitive type words.
# It intentionally does NOT allow `[TOKEN: ...]` unsafe blocks — use
# dictum_unsafe.gbnf for generation inside `unsafe:` blocks.

root          ::= top-level-item+

top-level-kw  ::= "action" | "end" | "import" | "module" | "program" | "shape"

statement-kw  ::= "C" | "Type" | "a" | "action" | "all" | "alone" | "and" | "any" | "as" | "assert" | "at" | "attempt" | "bind" | "bitwise" | "by" | "call" | "const" | "constructor" | "cosine" | "defer" | "define" | "destructor" | "difference" | "divided" | "each" | "empty" | "end" | "equal" | "exponential" | "export" | "extends" | "extern" | "failure" | "false" | "fn" | "for" | "from" | "giving" | "greater" | "holding" | "holds" | "if" | "import" | "in" | "into" | "is" | "item" | "keep" | "least" | "left" | "length" | "less" | "method" | "minus" | "modulo" | "most" | "move" | "new" | "newline" | "no" | "not" | "nothing" | "of" | "on" | "or" | "otherwise" | "override" | "plus" | "possibilities" | "power" | "print" | "private" | "produce" | "produces" | "product" | "protected" | "public" | "put" | "quotient" | "raw" | "ref" | "release" | "remainder" | "repeat" | "repeating" | "return" | "right" | "room" | "root" | "run" | "set" | "shape" | "shared" | "shift" | "sine" | "square" | "stop" | "success" | "sum" | "syscall" | "takes" | "taking" | "tanh" | "than" | "the" | "then" | "times" | "transmute" | "true" | "unique" | "unsafe" | "use" | "using" | "values" | "virtual" | "weak" | "while" | "with"

type-word     ::= "array" | "bool" | "byte" | "bytes" | "const" | "count" | "decimal" | "f32" | "fractional" | "handle" | "i32" | "i64" | "list" | "move" | "nothing" | "number" | "of" | "opaque" | "pointer" | "raw" | "ref" | "result" | "shared" | "text" | "to" | "truth" | "u16" | "u32" | "u64" | "u8" | "unique" | "value" | "weak" | "whole"

# Structural tokens are left permissive (identifiers, numbers, strings,
# operators) — the parser's recursive-descent grammar (grammar.py) remains
# the authority for full structural validation; this GBNF only constrains
# the keyword surface for LLM sampling.
#
# FIX: the Build/Review pipeline requires the model to emit a
# [VERIFY: CATEGORY_ID] marker before each plan item's implementation (see
# extension.js's per-chunk prompt: "Emit [VERIFY: CATEGORY_ID] before each
# plan item above.", checked by validator.js against the exact pattern
# /\[VERIFY:\s*CATEGORY_ID\s*\]/i). That token is a Build-pipeline-only
# convention — it's never compiled to C/C++ and doesn't exist in
# compiler/dictumc/grammar.py or emit_c.py, which is everything this file
# is auto-generated FROM. So the generator had no way to know it needed
# this rule, and without it, grammar-constrained sampling makes emitting
# `[VERIFY: ...]` structurally impossible — not unlikely, IMPOSSIBLE, since
# `[`, `]`, and `:` were not reachable from any rule in this grammar at
# all. Every single L2 check failed on every single build regardless of
# model quality; the model, boxed out of ever satisfying the instruction
# and still permitted to emit unlimited bare `identifier` tokens (any
# letter sequence, including plain English words), free-associated through
# valid-but-meaningless identifier chains instead — which is what the
# repeated "If you can find the plan item..." text actually was: 100%
# grammar-legal noise, not the model literally quoting the prompt back
# and not a symptom of the fine-tune being undersized. verify-category's
# six names are chunking.js's own CHUNK_TIER_ORDER, the closed set of
# plan-item categories.
top-level-item ::= top-level-kw | statement-kw | type-word | identifier | number | string | ws | verify-token | punctuation | comment

verify-token    ::= "[" ws? "VERIFY" ws? ":" ws? verify-category "_" [0-9]+ ws? "]"
verify-category ::= "ARCHITECTURE" | "TYPE" | "INVARIANT" | "OPERATION" | "MEMORY" | "SAFETY"

# FIX (found via gbnf_check.py acceptance testing against real,
# already-compiling Dictum source): the auto-generator derived this
# grammar purely from grammar.py's keyword/type-word sets and never
# accounted for bare structural punctuation at all. As a result NONE
# of ":", ".", "-", or "#" were reachable anywhere outside the
# unrelated verify-token/unsafe-token literals -- which meant the
# mandatory trailing ":" on every single `program`/`module`/`shape`/
# `action` block opener could never be produced. Concretely: ZERO
# complete Dictum programs of any kind were derivable from this
# grammar's root rule, not just "some are missed" -- verified by
# feeding this project's own passing test corpus through a real GBNF
# matcher (gbnf_check.py) rather than assuming reachability from the
# keyword lists alone. Adding these fixes that unconditionally.
punctuation   ::= ":" | "." | "-"
comment       ::= "#" [^\n]*
identifier    ::= [a-zA-Z_][a-zA-Z0-9_]*
number        ::= [0-9]+ ("." [0-9]+)?
string        ::= "\"" [^"]* "\""
ws            ::= [ \t\n]+
